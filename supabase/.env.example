# Provider secrets for the edge functions. These live ONLY on the server
# (Supabase secrets), never in the app or in git. Copy to supabase/.env, fill in,
# then push them:
#
#   supabase secrets set --env-file supabase/.env
#
# Base URLs have sensible defaults in code; override here if the docs differ.

# --- Khaya (GhanaNLP) — Twi TTS + ASR. Get the key from the GhanaNLP portal. ---
KHAYA_API_KEY=
KHAYA_BASE_URL=https://translation-api.ghananlp.org

# --- Abena (Mobobi) — Ghanaian-English TTS (backup Twi). ---
ABENA_BASE_URL=https://abena.mobobi.com/api
ABENA_API_KEY=

# --- Whisper — English ASR. Using Groq hosted Whisper (recommended).
#     Get a free key at https://console.groq.com  (API Keys).
#     For a self-host instead, set WHISPER_BASE_URL to http://your-host:9000
#     and adjust WHISPER_MODEL to whatever your server exposes. ---
WHISPER_BASE_URL=https://api.groq.com/openai
WHISPER_API_KEY=
WHISPER_MODEL=whisper-large-v3-turbo

# --- Gemini — KasaAI brain (free tier). ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
