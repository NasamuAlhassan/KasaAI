# Provider secrets for the edge functions. These live ONLY on the server
# (Supabase secrets), never in the app or in git. Copy to supabase/.env, fill in,
# then push them:
#
#   supabase secrets set --env-file supabase/.env
#
# Base URLs have sensible defaults in code; override here if the docs differ.

# --- Khaya (GhanaNLP) — optional. Preferred for Twi TTS when set (falls back
#     to Abena automatically if this key is missing or the call fails), and
#     required for Twi ASR (only used by the "learn Twi" / reverse direction).
#     Get the key from the GhanaNLP portal. ---
KHAYA_API_KEY=
KHAYA_BASE_URL=https://translation-api.ghananlp.org

# --- Abena (Mobobi) — TTS for BOTH Twi and Ghanaian-English. No signup
#     required for the playground tier; ABENA_API_KEY can be left blank to
#     start. This alone is enough to test the primary (Twi -> English) loop
#     end to end, since that direction never needs Twi ASR. ---
ABENA_BASE_URL=https://abena.mobobi.com/playground/api/v1
ABENA_API_KEY=
ABENA_TWI_VOICE=abena_twi_high
ABENA_EN_VOICE=akua_eng

# --- Whisper — English ASR. Using Groq hosted Whisper (recommended).
#     Get a free key at https://console.groq.com  (API Keys).
#     For a self-host instead, set WHISPER_BASE_URL to http://your-host:9000
#     and adjust WHISPER_MODEL to whatever your server exposes. ---
WHISPER_BASE_URL=https://api.groq.com/openai
WHISPER_API_KEY=
WHISPER_MODEL=whisper-large-v3-turbo

# --- Gemini — KasaAI brain (free tier). ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
